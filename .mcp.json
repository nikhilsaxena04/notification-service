{
  "mcpServers": {
    "graphify": {
      "command": "uv",
      "args": [
        "run", "--with", "graphifyy", "--with", "mcp", "-m", "graphify.serve",
        "${workspace.path}/graphify-out/graph.json"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"]
    }
  }
}